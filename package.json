{
  "name": "nano-banana-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI image generation via Google Gemini with intelligent model routing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nano-banana-mcp": "dist/index.js"
  },
  "scripts": {
